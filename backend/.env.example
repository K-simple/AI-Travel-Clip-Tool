# 可选 API Key；设置后所有 /api 与 /storage 请求需携带 X-API-Key 头
# API_KEY=your-secret-key

# --- 处理预设（推荐只改这一行，其余由预设推导）---
# PROCESSING_PRESET=budget   budget(~3k PC 默认) | standard | dev | quality
# budget：Whisper small + FFmpeg 人声 + 低并行 + 跳过重 AI enrich，兼容 8G 内存
# AUTO_SUBTITLE_AFTER_INTAKE=1 intake 完成后后台 OCR+ASR 融合（base 模式默认跳过，由用户点击「识别字幕」）

# 画面槽创建：base（默认，上传后仅 1 个全片槽）| auto_visual（上传时 PySceneDetect 自动切槽）
# SLOT_CREATION_MODE=base

# CORS 允许来源（逗号分隔）
# CORS_ORIGINS=http://localhost:3000

# 上传大小限制（字节），默认 500MB
# MAX_UPLOAD_BYTES=524288000

# 数据库路径（默认 backend/ai_travel_cut.db）
# DATABASE_URL=sqlite:///./ai_travel_cut.db

# --- DeepSeek V4（镜头修正 + 中文画面描述，请勿提交到 Git）---
# DEEPSEEK_API_KEY=sk-xxxxxxxx
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# 若模型不支持 image_url 视觉输入，请设 ENABLE_AI_SHOT_REFINE=0 避免模板分析在 38% 附近长时间等待
# ENABLE_AI_SHOT_REFINE=1
# ENABLE_AI_LABELS=1
# AI_LABEL_MAX_ITEMS=80

# --- 旅游混剪镜头切分档位（模板一镜一槽）---
# TEMPLATE_FAST_EDIT_READY=1   约 30s intake：切分+AI画面+字幕花字，重活后台继续
# TEMPLATE_INTAKE_AI_WORKERS=4  并行 DeepSeek 槽位理解
# TEMPLATE_INTAKE_SUBTITLE_OCR=1  导入时批量 OCR 烧录字幕
# TEMPLATE_FAST_SKIP_AUTO_TUNE=1  快速阶段跳过 threshold 网格校准
# DEFER_TEMPLATE_PROXIES=1     预览代理延后到可编辑之后
# TEMPLATE_SCENE_INTERVAL_FALLBACK=0  禁用等间隔切分，仅按画面切分
# TEMPLATE_SCENE_PROFILE=travel_fast
#   travel_ultra | travel_fast | travel_normal | travel_slow
# TEMPLATE_SCENE_AUTO_TUNE=1
# TEMPLATE_SCENE_THRESHOLD=24
# MIN_TEMPLATE_SHOT_DURATION=0.18
# AI_SHOT_SPLIT_MIN_DURATION=1.4
# AI_SHOT_MAX_BOUNDARY_CHECKS=80

# --- CapCut Mate 剪映草稿导出 ---
# 1) 安装并启动剪映小助手（默认 http://localhost:30000）
# 2) 安装剪映 PC 版；导出后点击 draft_url 打开（勿手动新建空白草稿）
# CAPCUT_MATE_BASE_URL=http://localhost:30000
# CapCut Mate 拉取裁剪片段用的后端地址（不设则自动探测局域网 IP）
# PUBLIC_MEDIA_BASE_URL=http://192.168.1.10:8000
# CAPCUT_MATE_TIMEOUT_SEC=600
# CAPCUT_USE_LOCAL_FILES=1          同机部署时用 file:// 直传片段，避免 HTTP 逐段下载
# JIANYING_DRAFT_PATH=C:/Users/你的用户名/AppData/Local/JianyingPro/User Data/Projects/com.lveditor.draft
# CAPCUT_MATE_DRAFT_DIR=../capcut-mate/output/draft
# 若设置了 API_KEY，导出时会自动在 /storage URL 附带 api_key 供小助手访问

# --- 素材快速入库（默认 FAST_MODE 开启）---
# ASSET_FAST_EDIT_READY=1      先入库可拖拽，精分/代理/标签后台继续
# DEFER_ASSET_PROXIES=1        预览代理延后
# DEFER_ASSET_AI_LABELS=1      DeepSeek 标签延后
# ASSET_QUICK_SEGMENTS=1       快速阶段用等间隔镜头 + 单封面

# --- 模板 AI 特效理解（每槽调色/动效/字幕动画，需 DEEPSEEK_API_KEY）---
# ENABLE_TEMPLATE_EFFECTS_ANALYSIS=1
# TEMPLATE_EFFECTS_MAX_SLOTS=40

# --- 字幕花字样式 + 音效点位分析 ---
# ENABLE_SUBTITLE_STYLE_ANALYSIS=1   OpenCV 帧差识别烧录字幕颜色/动画（需 Whisper 字幕）
# ENABLE_SFX_DETECTION=1             librosa 检测叮/嗖等音效并写入 sfx_markers
# SUBTITLE_STYLE_MAX_SEGMENTS=40
# SFX_MIN_ENERGY=0.018
# DEFER_WHISPER=0                    若需上传后自动识别人声+花字，请关闭延迟 Whisper

# --- 智能字幕（剪映式：先 fast 并行，精识别再 HQ OCR 升级）---
# SUBTITLE_RECOGNITION_MODE=fast   intake/自动批次档位（quality 会显著变慢）
# SUBTITLE_SCAN_FPS=4              烧录字幕换句扫描帧率（budget 默认 4，约每 0.25s）
# ENABLE_SUBTITLE_TIMELINE_SCAN=1  剪映式：扫描字幕带变化 → 按句 OCR → 对齐槽位
# ENABLE_SUBTITLE_DRIVEN_SLOT_SPLIT=0  旧开关；1 且未设 STRATEGY 时等同 split_distinct
# SUBTITLE_SLOT_STRATEGY=align       默认：保留镜头槽，只写准字幕（约 25 句 ≈ 25 槽）
# SUBTITLE_SLOT_STRATEGY=split_distinct  仅同一镜头内 2 句不同字幕才拆槽
# SUBTITLE_SPLIT_MIN_SLOT_SEC=0.28   拆槽最短时长（秒）
# OCR_ENGINE=easyocr              paddle | easyocr（Paddle 中文烧录字通常更准）
# PADDLE_ENABLE_MKLDNN=0           Windows CPU 建议关闭，避免 oneDNN 报错
# WHISPER_BATCH_BEAM_SIZE=1        快速整段 ASR（约 30s 级全片）
# WHISPER_QUALITY_BEAM_SIZE=5      仅 segments 需重建时的精识别 ASR
# WHISPER_BEAM_SIZE=10             单段精转写上限（clip ASR 等）
# SUBTITLE_SLOT_WORD_PADDING_SEC=0.15
# SUBTITLE_CLIP_MIN_DURATION=0.8
# SUBTITLE_CLIP_MAX_DURATION=4.5
# SUBTITLE_CLIP_TARGET_DURATION=2.2
# SUBTITLE_CLIP_MAX_CHARS=22
# SUBTITLE_CLIP_MIN_CHARS=4
# SUBTITLE_CLIP_MAX_LINES=2
# SUBTITLE_CLIP_MAX_CHARS_PER_LINE=16
# SUBTITLE_CLIP_PAUSE_THRESHOLD_SEC=0.35
# SUBTITLE_CLIP_MERGE_GAP_SEC=0.25
# SUBTITLE_CLIP_USE_WORD_TIMESTAMPS=1
# 切槽策略: visual | speech | hybrid | caption_slot | sentence（默认一句一槽）
# CUT_STRATEGY=caption_slot
# MATERIAL_FILL_STRATEGY=fit_caption_slots
# CAPTION_SLOT_MIN_DURATION=0.8
# CAPTION_SLOT_MAX_DURATION=5.0
# CAPTION_SLOT_TARGET_DURATION=2.5
# CAPTION_SLOT_MAX_CHARS=28
# CAPTION_SLOT_MIN_CHARS=4
# CAPTION_SLOT_MERGE_GAP_SEC=0.25
# CAPTION_SLOT_USE_OCR_TEXT=1
# CAPTION_SLOT_USE_ASR_TIME=1
# CAPTION_SLOT_OCR_ASR_SIM_THRESHOLD=0.55
# CAPTION_SLOT_OCR_SUBTITLE_SCORE_THRESHOLD=0.65
# intake 阶段 OCR 始终 fast；超 TEMPLATE_INTAKE_BUDGET_SEC 时跳过花字 enrich
# TEMPLATE_INTAKE_BUDGET_SEC=30
# 识别模式: visual | audio | auto（接口 mode 参数，前端默认 auto）
# OCR_PREFER_VISION=0              设为 1 时优先 DeepSeek 视觉 OCR
# OCR_USE_GPU=0
# WHISPER_MODEL=medium
# WHISPER_MODEL_FALLBACKS=small,base
# WHISPER_COMPUTE_TYPE=int8
# WHISPER_BEAM_SIZE=10
# WHISPER_BATCH_BEAM_SIZE=1
# WHISPER_QUALITY_BEAM_SIZE=5
# SUBTITLE_OCR_WORKERS=4
# SUBTITLE_BATCH_WORKERS=2
# WHISPER_INITIAL_PROMPT=以下是中文旅行短视频旁白，使用规范简体中文和标点。
